# MANTIS Environment Variables

# Required: Anthropic API Key
ANTHROPIC_API_KEY=

# Mantle RPC (public, free)
MANTLE_RPC_URL=https://rpc.mantle.xyz

# Demo wallet address (read-only, for dashboard display)
NEXT_PUBLIC_DEMO_WALLET=0x0000000000000000000000000000000000000000

# Agent wallet private key (only needed for execute mode)
AGENT_WALLET_PRIVATE_KEY=

# Agent config: simulate or execute
EXECUTION_MODE=simulate
